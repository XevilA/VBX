<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="VBX Dispensing Control System" 
           Manufacturer="VBX Professional" 
           Version="1.0.0" 
           UpgradeCode="7d4a5b6c-8e9f-4a3b-b2c1-d3e4f5a6b7c8">
    
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="VBX_DispensingSystem" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Guid="8e9f4a3b-b2c1-d3e4-f5a6-b7c8d9e0f1a2">
        <File Source="C:\Users\Administrator\Documents\VBX\DispensingControlSystem\bin\Release\net8.0-windows\$(var.Rid)\publish\DispensingControlSystem.exe" Id="MainExe" KeyPath="yes">
          <Shortcut Id="DesktopShortcut" 
                    Directory="DesktopFolder" 
                    Name="VBX Dispensing System" 
                    WorkingDirectory="INSTALLFOLDER" 
                    Advertise="yes" />
        </File>
      </Component>
    </ComponentGroup>

    <Feature Id="Main">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>
  </Package>
</Wix>
